# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#
# SECRET_API_KEY — example secret used to demonstrate the .env-protection
# tooling (see hooks/read_hook.js). No application code currently reads it.
SECRET_API_KEY="your-secret-api-key-here"

# SLACK_BOT_TOKEN — bot token used by src/slack.ts to post pending-order
# alerts to #order-alerts via chat.postMessage. Needs chat:write scope.
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token-here"
